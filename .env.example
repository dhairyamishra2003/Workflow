# Server
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/agentflow_ai
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
CREDENTIAL_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
CLIENT_URL=http://localhost:3000
REDIS_URL=redis://localhost:6379

# AI Providers (at least one recommended; deterministic fallback works without either)
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# OAuth — Gmail / Google Sheets (shared Google OAuth app)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/integrations/oauth/gmail/callback

# OAuth — Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:5000/api/integrations/oauth/slack/callback

# OAuth — Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5000/api/integrations/oauth/discord/callback

# Client
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
